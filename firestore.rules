rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isSharedMember(sharedAccountId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/sharedAccounts/$(sharedAccountId)/members/$(request.auth.uid));
    }

    function sharedAccountExists(sharedAccountId) {
      return exists(/databases/$(database)/documents/sharedAccounts/$(sharedAccountId));
    }

    function sharedAccountOwner(sharedAccountId) {
      return get(/databases/$(database)/documents/sharedAccounts/$(sharedAccountId)).data.ownerUserId;
    }

    function isSharedOwner(sharedAccountId) {
      return isAuthenticated() &&
        sharedAccountExists(sharedAccountId) &&
        sharedAccountOwner(sharedAccountId) == request.auth.uid;
    }

    function canAccessSharedAccount(sharedAccountId) {
      return isSharedMember(sharedAccountId) || isSharedOwner(sharedAccountId);
    }

    function isSharedRecordCreator() {
      return isAuthenticated() && resource.data.createdByUserId == request.auth.uid;
    }

    function isSharedRecordLegacyOwner(sharedAccountId) {
      return isAuthenticated() &&
        (resource.data.createdByUserId == null || resource.data.createdByUserId == '') &&
        isSharedOwner(sharedAccountId);
    }

    function canCreateSharedRecord(sharedAccountId) {
      return canAccessSharedAccount(sharedAccountId) &&
        request.resource.data.createdByUserId == request.auth.uid;
    }

    function canUpdateSharedRecord(sharedAccountId) {
      return canAccessSharedAccount(sharedAccountId) &&
        (
          resource.data.createdByUserId == request.auth.uid ||
          isSharedRecordLegacyOwner(sharedAccountId)
        ) &&
        request.resource.data.createdByUserId == resource.data.createdByUserId;
    }
    
    // Link tokens - Cloud Functions only (Admin SDK bypasses rules)
    match /link_tokens/{token} {
      allow read, write: if false;
    }
    
    // User data
    match /users/{userId} {
      // User can read/write own data
      allow read, write: if isOwner(userId);

      // Account-scoped data
      match /accounts/{accountId} {
        allow read, write: if isOwner(userId);

        match /categories/{categoryId} {
          allow read, write: if isOwner(userId);
        }

        match /transactions/{transactionId} {
          allow read, write: if isOwner(userId);
        }

        match /plans/{planId} {
          allow read, write: if isOwner(userId);
        }

        match /budgets/{budgetId} {
          allow read, write: if isOwner(userId);
        }

        match /debts/{debtId} {
          allow read, write: if isOwner(userId);
        }

        match /simulations/{simulationId} {
          allow read, write: if isOwner(userId);
        }
      }
      
      // Legacy Categories
      match /categories/{categoryId} {
        allow read, write: if isOwner(userId);
      }
      
      // Legacy Transactions
      match /transactions/{transactionId} {
        allow read, write: if isOwner(userId);
      }
      
      // Legacy Simulations
      match /simulations/{simulationId} {
        allow read, write: if isOwner(userId);
      }
      
      // Telegram link
      match /telegram_link/{linkId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /sharedAccounts/{sharedAccountId} {
      allow read: if canAccessSharedAccount(sharedAccountId);
      allow write: if false;

      match /members/{memberId} {
        allow read: if canAccessSharedAccount(sharedAccountId);
        allow write: if false;
      }

      match /categories/{categoryId} {
        allow read: if canAccessSharedAccount(sharedAccountId);
        allow create: if canCreateSharedRecord(sharedAccountId);
        allow update, delete: if canUpdateSharedRecord(sharedAccountId);
      }

      match /transactions/{transactionId} {
        allow read: if canAccessSharedAccount(sharedAccountId);
        allow create: if canCreateSharedRecord(sharedAccountId);
        allow update, delete: if canUpdateSharedRecord(sharedAccountId);
      }

      match /plans/{planId} {
        allow read: if canAccessSharedAccount(sharedAccountId);
        allow create: if canCreateSharedRecord(sharedAccountId);
        allow update, delete: if canUpdateSharedRecord(sharedAccountId);
      }

      match /budgets/{budgetId} {
        allow read: if canAccessSharedAccount(sharedAccountId);
        allow create: if canCreateSharedRecord(sharedAccountId);
        allow update, delete: if canUpdateSharedRecord(sharedAccountId);
      }

      match /debts/{debtId} {
        allow read: if canAccessSharedAccount(sharedAccountId);
        allow create: if canCreateSharedRecord(sharedAccountId);
        allow update, delete: if canUpdateSharedRecord(sharedAccountId);
      }

      match /simulations/{simulationId} {
        allow read: if canAccessSharedAccount(sharedAccountId);
        allow create: if canCreateSharedRecord(sharedAccountId);
        allow update, delete: if canUpdateSharedRecord(sharedAccountId);
      }
    }
    
    // Rate limits - Cloud Functions only
    match /telegram_rate_limits/{telegramId} {
      allow read, write: if false; // Cloud Functions use Admin SDK
    }
  }
}
