rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Link tokens - allow read/write for validation
    match /link_tokens/{token} {
      allow read, write: if true; // Temporary for development
      // TODO: Restrict to Cloud Functions only in production
    }
    
    // User data
    match /users/{userId} {
      // User can read/write own data
      allow read, write: if isOwner(userId);
      
      // Categories
      match /categories/{categoryId} {
        allow read, write: if isOwner(userId);
      }
      
      // Transactions
      match /transactions/{transactionId} {
        allow read, write: if isOwner(userId);
      }
      
      // Simulations
      match /simulations/{simulationId} {
        allow read, write: if isOwner(userId);
      }
      
      // Telegram link
      match /telegram_link/{linkId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // Rate limits - Cloud Functions only
    match /telegram_rate_limits/{telegramId} {
      allow read, write: if false; // Cloud Functions use Admin SDK
    }
  }
}
