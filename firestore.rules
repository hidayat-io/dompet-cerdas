rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isSharedMember(sharedAccountId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/sharedAccounts/$(sharedAccountId)/members/$(request.auth.uid));
    }
    
    // Link tokens - Cloud Functions only (Admin SDK bypasses rules)
    match /link_tokens/{token} {
      allow read, write: if false;
    }
    
    // User data
    match /users/{userId} {
      // User can read/write own data
      allow read, write: if isOwner(userId);

      // Account-scoped data
      match /accounts/{accountId} {
        allow read, write: if isOwner(userId);

        match /categories/{categoryId} {
          allow read, write: if isOwner(userId);
        }

        match /transactions/{transactionId} {
          allow read, write: if isOwner(userId);
        }

        match /plans/{planId} {
          allow read, write: if isOwner(userId);
        }

        match /budgets/{budgetId} {
          allow read, write: if isOwner(userId);
        }

        match /debts/{debtId} {
          allow read, write: if isOwner(userId);
        }

        match /simulations/{simulationId} {
          allow read, write: if isOwner(userId);
        }
      }
      
      // Legacy Categories
      match /categories/{categoryId} {
        allow read, write: if isOwner(userId);
      }
      
      // Legacy Transactions
      match /transactions/{transactionId} {
        allow read, write: if isOwner(userId);
      }
      
      // Legacy Simulations
      match /simulations/{simulationId} {
        allow read, write: if isOwner(userId);
      }
      
      // Telegram link
      match /telegram_link/{linkId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /sharedAccounts/{sharedAccountId} {
      allow read: if isSharedMember(sharedAccountId);
      allow write: if false;

      match /members/{memberId} {
        allow read: if isSharedMember(sharedAccountId);
        allow write: if false;
      }

      match /categories/{categoryId} {
        allow read, write: if isSharedMember(sharedAccountId);
      }

      match /transactions/{transactionId} {
        allow read, write: if isSharedMember(sharedAccountId);
      }

      match /plans/{planId} {
        allow read, write: if isSharedMember(sharedAccountId);
      }

      match /budgets/{budgetId} {
        allow read, write: if isSharedMember(sharedAccountId);
      }

      match /debts/{debtId} {
        allow read, write: if isSharedMember(sharedAccountId);
      }

      match /simulations/{simulationId} {
        allow read, write: if isSharedMember(sharedAccountId);
      }
    }
    
    // Rate limits - Cloud Functions only
    match /telegram_rate_limits/{telegramId} {
      allow read, write: if false; // Cloud Functions use Admin SDK
    }
  }
}
